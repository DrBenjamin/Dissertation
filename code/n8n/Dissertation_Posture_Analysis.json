    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item, index) => {\n  const existingKey = item.json?.object_name;\n  const sourcePath = existingKey || item.json?.source_object_name || item.json?.object?.name || item.json?.name || item.binary?.data?.fileName || `object_${Date.now()}_${index}.jpg`;\n\n  const safeKey = String(sourcePath)\n    .split('/')\n    .filter(Boolean)\n    .map((segment) => segment.replace(/[^a-zA-Z0-9._-]/g, '_'))\n    .join('/');\n\n  const fallbackKey = `processed/object_${Date.now()}_${index}.jpg`;\n\n  item.json = {\n    ...item.json,\n    object_name: safeKey || fallbackKey,\n  };\n\n  return item;\n});"
      },
