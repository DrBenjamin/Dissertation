    },
    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\nconst out = [];\n\nconst sanitize = (value) => String(value)\n  .split('/')\n  .filter(Boolean)\n  .map((segment) => segment.replace(/[^a-zA-Z0-9._-]/g, '_'))\n  .join('/');\n\nconst pickName = (obj) => {\n  if (!obj) return null;\n  if (typeof obj === 'string') return obj;\n  return obj.name || obj.objectName || obj.key || obj.path || null;\n};\n\nfor (const item of inputItems) {\n  const directName = pickName(item?.json?.object) || pickName(item?.json);\n  if (directName) {\n    out.push({\n      json: {\n        ...item.json,\n        source_object_name: directName,\n        object: {\n          ...(item.json?.object || {}),\n          name: directName,\n        },\n        object_name: sanitize(directName),\n      },\n      binary: item.binary,\n    });\n    continue;\n  }\n\n  const listCandidates = [\n    item?.json?.objects,\n    item?.json?.data,\n    item?.json?.items,\n    item?.json?.list,\n    item?.json?.contents,\n    ...(item?.json ? Object.values(item.json).filter(Array.isArray) : []),\n  ];\n\n  let expanded = false;\n  for (const arr of listCandidates) {\n    if (!Array.isArray(arr) || arr.length === 0) continue;\n\n    for (const obj of arr) {\n      const objectName = pickName(obj);\n      if (!objectName) continue;\n\n      out.push({\n        json: {\n          ...item.json,\n          source_object_name: objectName,\n          object: {\n            ...(typeof obj === 'object' ? obj : {}),\n            name: objectName,\n          },\n          object_name: sanitize(objectName),\n        },\n        binary: item.binary,\n      });\n    }\n\n    expanded = true;\n    break;\n  }\n\n  if (!expanded) {\n    // Keep visibility of unrecognized payloads instead of silently dropping data.\n    out.push(item);\n  }\n}\n\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
